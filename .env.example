# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://compound_user:compound_pass@localhost:5432/compound_meds

# Azure Storage (production only)
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=media

# Email (dev uses console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@farmix.pt

# Sentry (production only)
SENTRY_DSN=

# Language
LANGUAGE_CODE=pt-pt

# CSRF trusted origins (production only, comma-separated)
# Example: https://farmix.azurewebsites.net,https://farmix.pt
CSRF_TRUSTED_ORIGINS=

# Field encryption key (Fernet base64 URL-safe, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=
